<style>
  .sfaq[data-block-id="{{ block.id }}"] {
    --sfaq-heading-color: {{ block.settings.heading_color }};
    --sfaq-accent: {{ block.settings.accent_color }};
    --sfaq-heading-size: {{ block.settings.heading_font_size }}px;
    --sfaq-question-size: {{ block.settings.question_font_size }}px;
    --sfaq-gap: {{ block.settings.question_gap }}px;
  }
</style>

<div class="sfaq" data-block-id="{{ block.id }}">
  {% if block.settings.heading != blank %}
    <h2 class="sfaq-heading">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.show_search %}
    <div class="sfaq-search">
      <svg
        class="sfaq-search-icon"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
      </svg>
      <input
        type="text"
        class="sfaq-search-input"
        placeholder="Search FAQs..."
        aria-label="Search frequently asked questions"
      >
    </div>
  {% endif %}

  {% if block.settings.layout == 'accordion' %}
    <div class="sfaq-accordion" role="list">
      <details class="sfaq-item" role="listitem" {% if block.settings.first_item_open %}open{% endif %}>
        <summary class="sfaq-question">
          How do I track my order?
          <svg class="sfaq-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="sfaq-answer">
          <p>Once your order ships, you'll receive a confirmation email with a tracking number. You can use this number to track your package on our shipping partner's website. Orders typically ship within 1-2 business days.</p>
        </div>
      </details>

      <details class="sfaq-item" role="listitem">
        <summary class="sfaq-question">
          What is your return policy?
          <svg class="sfaq-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="sfaq-answer">
          <p>We offer a 30-day return policy from the date of delivery. Items must be unused and in their original packaging. To initiate a return, please contact our support team with your order number and reason for return.</p>
          <ul>
            <li>Full refund for items returned within 14 days</li>
            <li>Store credit for items returned between 15-30 days</li>
            <li>Free return shipping on defective items</li>
          </ul>
        </div>
      </details>

      <details class="sfaq-item" role="listitem">
        <summary class="sfaq-question">
          How long does shipping take?
          <svg class="sfaq-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="sfaq-answer">
          <p>Shipping times vary based on your location and the shipping method selected:</p>
          <ul>
            <li><strong>Standard (Free):</strong> 5-8 business days</li>
            <li><strong>Express:</strong> 2-3 business days</li>
            <li><strong>Priority:</strong> 1-2 business days</li>
          </ul>
        </div>
      </details>

      <details class="sfaq-item" role="listitem">
        <summary class="sfaq-question">
          What payment methods do you accept?
          <svg class="sfaq-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="sfaq-answer">
          <p>We accept all major payment methods including Visa, Mastercard, American Express, PayPal, Apple Pay, and Google Pay. All transactions are securely processed and your payment information is never stored on our servers.</p>
        </div>
      </details>

      <details class="sfaq-item" role="listitem">
        <summary class="sfaq-question">
          Can I change or cancel my order?
          <svg class="sfaq-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="sfaq-answer">
          <p>You can modify or cancel your order within 1 hour of placement. After that, the order enters processing and we cannot guarantee changes. Please contact our support team immediately with your order number if you need to make a change.</p>
        </div>
      </details>

      <details class="sfaq-item" role="listitem">
        <summary class="sfaq-question">
          Do you ship internationally?
          <svg class="sfaq-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="sfaq-answer">
          <p>Yes, we ship to over 50 countries worldwide. International shipping rates and delivery times vary by destination. Please note that customs duties and taxes may apply and are the responsibility of the customer. Standard international shipping takes 10-15 business days.</p>
        </div>
      </details>
    </div>
  {% else %}
    <div class="sfaq-list">
      <div class="sfaq-list-item">
        <div class="sfaq-list-question">How do I track my order?</div>
        <div class="sfaq-list-answer">Once your order ships, you'll receive a confirmation email with a tracking number. You can use this number to track your package on our shipping partner's website. Orders typically ship within 1-2 business days.</div>
      </div>

      <div class="sfaq-list-item">
        <div class="sfaq-list-question">What is your return policy?</div>
        <div class="sfaq-list-answer">We offer a 30-day return policy from the date of delivery. Items must be unused and in their original packaging. To initiate a return, please contact our support team with your order number and reason for return.</div>
      </div>

      <div class="sfaq-list-item">
        <div class="sfaq-list-question">How long does shipping take?</div>
        <div class="sfaq-list-answer">Shipping times vary based on your location and the shipping method selected. Standard shipping takes 5-8 business days, Express takes 2-3 business days, and Priority takes 1-2 business days.</div>
      </div>

      <div class="sfaq-list-item">
        <div class="sfaq-list-question">What payment methods do you accept?</div>
        <div class="sfaq-list-answer">We accept Visa, Mastercard, American Express, PayPal, Apple Pay, and Google Pay. All transactions are securely processed and your payment information is never stored on our servers.</div>
      </div>

      <div class="sfaq-list-item">
        <div class="sfaq-list-question">Can I change or cancel my order?</div>
        <div class="sfaq-list-answer">You can modify or cancel your order within 1 hour of placement. After that, the order enters processing and we cannot guarantee changes. Please contact our support team immediately with your order number if you need to make a change.</div>
      </div>

      <div class="sfaq-list-item">
        <div class="sfaq-list-question">Do you ship internationally?</div>
        <div class="sfaq-list-answer">Yes, we ship to over 50 countries worldwide. International shipping rates and delivery times vary by destination. Customs duties and taxes may apply and are the responsibility of the customer.</div>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Smart FAQ",
  "target": "section",
  "stylesheet": "smart-faq.css",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "accordion", "label": "Accordion" },
        { "value": "list", "label": "List" }
      ],
      "default": "accordion"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Enable search bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "first_item_open",
      "label": "Open first item by default",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#4f46e5"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size",
      "min": 16,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "question_font_size",
      "label": "Question size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "question_gap",
      "label": "Spacing between items",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ]
}
{% endschema %}
