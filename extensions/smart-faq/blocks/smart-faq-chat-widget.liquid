<style>
  .sfaq-widget[data-block-id="{{ block.id }}"] {
    --sfaq-accent: {{ block.settings.accent_color }};
  }
</style>

<div class="sfaq-widget" data-block-id="{{ block.id }}">
  <input
    type="checkbox"
    id="sfaq-widget-toggle-{{ block.id }}"
    class="sfaq-widget-toggle"
    aria-hidden="true"
  >

  <label for="sfaq-widget-toggle-{{ block.id }}" class="sfaq-widget-trigger" aria-label="Toggle FAQ chat widget" role="button" tabindex="0">
    <svg class="sfaq-widget-trigger-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <svg class="sfaq-widget-trigger-close-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
    {{ block.settings.trigger_text }}
  </label>

  <div class="sfaq-widget-pulse" aria-hidden="true"></div>

  <div class="sfaq-widget-panel" role="dialog" aria-label="{{ block.settings.heading }}">
    <div class="sfaq-widget-header">
      <div class="sfaq-widget-header-left">
        <svg class="sfaq-widget-header-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <div>
          <div class="sfaq-widget-header-text">{{ block.settings.heading }}</div>
          <div class="sfaq-widget-header-sub">{{ block.settings.subheading }}</div>
        </div>
      </div>
      <label for="sfaq-widget-toggle-{{ block.id }}" class="sfaq-widget-close-btn" aria-label="Close chat widget" role="button" tabindex="0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </label>
    </div>

    <div class="sfaq-widget-body">
      {% if block.settings.show_search %}
        <div class="sfaq-widget-search">
          <svg class="sfaq-widget-search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
          </svg>
          <input
            type="text"
            class="sfaq-widget-search-input"
            placeholder="Search FAQs..."
            aria-label="Search frequently asked questions"
          >
        </div>
      {% endif %}

      {% if block.settings.show_suggested %}
        <div class="sfaq-widget-suggested-label">{{ block.settings.suggested_label }}</div>
        <div class="sfaq-widget-suggested">
          <button class="sfaq-widget-chip" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Track my order
          </button>
          <button class="sfaq-widget-chip" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Return policy
          </button>
          <button class="sfaq-widget-chip" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Shipping time
          </button>
          <button class="sfaq-widget-chip" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Payment methods
          </button>
        </div>
      {% endif %}

      <div class="sfaq-widget-items">
        <details class="sfaq-widget-item">
          <summary class="sfaq-widget-question">
            How do I track my order?
            <svg class="sfaq-widget-question-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="sfaq-widget-answer">
            <p>Once your order ships, you'll receive a confirmation email with a tracking number. You can use it to track your package on our shipping partner's website.</p>
          </div>
        </details>

        <details class="sfaq-widget-item">
          <summary class="sfaq-widget-question">
            What is your return policy?
            <svg class="sfaq-widget-question-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="sfaq-widget-answer">
            <p>We offer a 30-day return policy from the date of delivery. Items must be unused and in their original packaging.</p>
          </div>
        </details>

        <details class="sfaq-widget-item">
          <summary class="sfaq-widget-question">
            How long does shipping take?
            <svg class="sfaq-widget-question-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="sfaq-widget-answer">
            <p>Standard shipping takes 5-8 business days. Express shipping takes 2-3 business days. Priority shipping takes 1-2 business days.</p>
          </div>
        </details>

        <details class="sfaq-widget-item">
          <summary class="sfaq-widget-question">
            What payment methods do you accept?
            <svg class="sfaq-widget-question-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="sfaq-widget-answer">
            <p>We accept Visa, Mastercard, American Express, PayPal, Apple Pay, and Google Pay.</p>
          </div>
        </details>

        <details class="sfaq-widget-item">
          <summary class="sfaq-widget-question">
            Can I change or cancel my order?
            <svg class="sfaq-widget-question-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="sfaq-widget-answer">
            <p>You can modify or cancel your order within 1 hour of placement. After that, it enters processing and we cannot guarantee changes.</p>
          </div>
        </details>

        <details class="sfaq-widget-item">
          <summary class="sfaq-widget-question">
            Do you ship internationally?
            <svg class="sfaq-widget-question-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="sfaq-widget-answer">
            <p>Yes, we ship to over 50 countries worldwide. International shipping takes 10-15 business days. Customs duties may apply.</p>
          </div>
        </details>
      </div>
    </div>

    {% if block.settings.show_contact %}
      <div class="sfaq-widget-footer">
        <div class="sfaq-widget-footer-text">{{ block.settings.contact_heading }}</div>
        <a href="{{ block.settings.contact_link }}" class="sfaq-widget-footer-link">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {{ block.settings.contact_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Smart FAQ Chat Widget",
  "target": "body",
  "stylesheet": "smart-faq-widget.css",
  "settings": [
    {
      "type": "text",
      "id": "trigger_text",
      "label": "Trigger button text",
      "default": "Chat"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Panel heading",
      "default": "How can we help?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Panel subheading",
      "default": "Find answers to common questions"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Enable search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_suggested",
      "label": "Show suggested questions",
      "default": true
    },
    {
      "type": "text",
      "id": "suggested_label",
      "label": "Suggested questions label",
      "default": "Quick answers"
    },
    {
      "type": "checkbox",
      "id": "show_contact",
      "label": "Show contact footer",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Still need help?"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact button text",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#4f46e5"
    }
  ]
}
{% endschema %}
